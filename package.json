{
  "name": "fidelity-apple-wallet",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18 <24"
  },
  "scripts": {
    "setup": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "backend": "node scripts/free-backend-port.mjs && node backend/src/index.js",
    "backend:free-port": "node scripts/free-backend-port.mjs",
    "frontend": "npm run dev --prefix frontend",
    "dev": "node scripts/start-all.mjs",
    "dev:local": "node scripts/dev-local.mjs up",
    "dev:local:status": "node scripts/dev-local.mjs status",
    "dev:local:stop": "node scripts/dev-local.mjs down",
    "dev:guardian": "node scripts/dev-guardian.mjs",
    "dev:auto:install": "node scripts/install-dev-local-agent.mjs",
    "dev:auto:uninstall": "node scripts/uninstall-dev-local-agent.mjs",
    "start": "npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "lint": "eslint backend/src frontend/src scripts",
    "lint:fix": "eslint backend/src frontend/src scripts --fix",
    "deploy": "sh scripts/deploy.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.0.3"
  }
}

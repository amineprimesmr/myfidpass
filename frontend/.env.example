# Optionnel. En local, par défaut le front appelle le backend via le proxy (port 3001).
# Pour tester l’API de PRODUCTION depuis localhost (ex. roue, spin), définis :
# VITE_API_URL=https://api.myfidpass.fr

# Connexion Google / Apple (onboarding, checkout, auth)
# À configurer aussi sur Vercel pour la prod. Voir docs/CONNEXION-GOOGLE-APPLE.md
# VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# VITE_APPLE_CLIENT_ID=fr.myfidpass.service

# Liens des apps natives (interstitiel mobile après paiement Stripe sur /app)
# VITE_APP_STORE_IOS_URL=https://apps.apple.com/app/idXXXXXXXX
# VITE_APP_STORE_ANDROID_URL=https://play.google.com/store/apps/details?id=fr.myfidpass.app

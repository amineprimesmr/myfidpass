{
  "name": "fidelity-apple-wallet",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18 <24"
  },
  "scripts": {
    "setup": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "backend": "node backend/src/index.js",
    "frontend": "npm run dev --prefix frontend",
    "dev": "node scripts/start-all.mjs",
    "start": "npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "lint": "eslint backend/src frontend/src scripts",
    "lint:fix": "eslint backend/src frontend/src scripts --fix",
    "deploy": "sh scripts/deploy.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.0.3"
  }
}

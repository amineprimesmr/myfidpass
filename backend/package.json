    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fast-jwt": "^6.1.0",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "passkit-generator": "^3.5.7",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "stripe": "^20.4.0",
    "web-push": "^3.6.7"
  },

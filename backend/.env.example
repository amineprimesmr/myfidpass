# Copie ce fichier en .env et remplis les valeurs.
# En production (Railway/Render), ajoute ces variables dans le dashboard.

# Serveur
PORT=3001

# Apple Wallet (obligatoire pour générer les passes)
PASS_TYPE_ID=pass.com.fidelity
TEAM_ID=ton_team_id_apple
ORGANIZATION_NAME=Carte fidelite

# URL publique de l’API (sans slash final), ex. https://api.myfidpass.fr
# Utilisée pour OAuth (redirect_uri X/Twitter, Google, etc.) — doit être identique à l’URL réelle Railway / DNS.
# Si tu ne la définis pas, le serveur tente de deviner depuis les en-têtes (moins fiable derrière certains proxies).
# API_URL=https://api.myfidpass.fr

# URL du backend (obligatoire pour que l'iPhone s'enregistre et reçoive les notifications)
# Sans cette variable, le pass ne contient pas l'URL d'enregistrement → "Aucun appareil enregistré".
# Mettre l'URL publique de ton API (sans slash final), ex. https://api.myfidpass.fr
PASSKIT_WEB_SERVICE_URL=https://api.myfidpass.fr

# CORS : URL du site en production
FRONTEND_URL=https://myfidpass.fr

# Optionnel : si ta clé certificat Apple est protégée par mot de passe
# SIGNER_KEY_PASSPHRASE=ton_mot_de_passe

# Certificats Apple Wallet (au choix) :
# 1) Fichiers dans backend/certs/ : wwdr.pem, signerCert.pem, signerKey.pem
# 2) Variables (recommandé en prod) : WWDR_PEM, SIGNER_CERT_PEM, SIGNER_KEY_PEM
#    = contenu complet de chaque fichier .pem (copier-coller). Voir docs/APPLE-WALLET-SETUP.md

# Google Places (optionnel — pour la suggestion de couleurs depuis la photo du lieu)
# Même clé que sur Vercel (VITE_GOOGLE_PLACES_API_KEY) ou une clé serveur.
# GOOGLE_PLACES_API_KEY=AIza...

# Google Wallet (optionnel — pour les utilisateurs Android)
# Voir docs/GOOGLE-WALLET-SETUP.md
# GOOGLE_WALLET_ISSUER_ID=33880000000123456789
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...","client_email":"...@....iam.gserviceaccount.com",...}

# Notifications push (production) — obligatoire pour que les notifications restent actives après redémarrage.
# Générer une fois : npm run generate-vapid-keys (dans backend/)
# Puis ajouter les deux valeurs dans Railway (Variables du service backend).
# VAPID_PUBLIC_KEY=BDcrXOd-Cs3S1yVlCCHv7O7aXXAtZ7APYrw4rfSIsmyZB-6EZzsT8zxTPdr19Gy40lCj_79F9RF2Aj5jvwdjNZ4
# VAPID_PRIVATE_KEY=<copier la clé privée affichée par npm run generate-vapid-keys>

# Connexion Google et Apple (optionnel — affiche les boutons « Continuer avec Google » et « Apple »)
# Créer un projet Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID (Web).
# Pour Apple : Developer → Certificates, IDs & Profiles → Identifiers → Services ID.
# Même valeur côté frontend (Vercel) : VITE_GOOGLE_CLIENT_ID et VITE_APPLE_CLIENT_ID.
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# APPLE_CLIENT_ID=com.ton.domaine.service (Services ID Apple)

# OAuth X (Twitter) — bouton « Connexion API — X » dans l’app iOS (profil commerce)
# Portail : https://developer.x.com → projet → application → clés OAuth 2.0 (Client ID + Client Secret).
# Type : client confidentiel (le backend échange le code contre un token avec le secret).
# Callback HTTPS à déclarer EXACTEMENT sur X (User authentication settings → OAuth 2.0) :
#   https://api.myfidpass.fr/api/oauth/twitter/callback
# (remplace le domaine si ton API_URL est différent : même base + /api/oauth/twitter/callback)
# Scopes utilisés par l’API : users.read, offline.access
# TWITTER_OAUTH2_CLIENT_ID=...
# TWITTER_OAUTH2_CLIENT_SECRET=...

# Optionnel (dev) : pour activer le bouton « Reset tout » en production, définir un secret.
# RESET_SECRET=une_chaîne_secrète_longue

# Mot de passe oublié : envoi d’email (obligatoire en prod pour recevoir le lien).
# Voir docs/EMAIL-TRANSACTIONNEL.md
#
# Option A — Resend (recommandé). Voir docs/EMAIL-TRANSACTIONNEL.md (onboarding vs domaine vérifié).
# RESEND_API_KEY=re_xxxxxxxx
# Sans MAIL_FROM ni RESEND_FROM : expéditeur par défaut onboarding@resend.dev (limites Resend sur les destinataires).
# Après vérif DNS du domaine sur resend.com/domains :
# RESEND_FROM=Myfidpass <noreply@myfidpass.fr>
# ou MAIL_FROM=Myfidpass <noreply@myfidpass.fr>
#
# Option B — SMTP classique
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=xxx
# MAIL_FROM=noreply@myfidpass.fr
